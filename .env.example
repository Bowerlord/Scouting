# KCorp Scouting Tool — Variables d'environnement
# ══════════════════════════════════════════════════════════════════════════════
# Copiez ce fichier en .env et remplissez les valeurs.
#   cp .env.example .env

# Riot Games API Key (optionnel — pour données Solo Queue uniquement)
# Obtenir une clé : https://developer.riotgames.com
RIOT_API_KEY=

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
