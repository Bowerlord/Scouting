# ══════════════════════════════════════════════════════════════════════════════
# KCorp Scouting Tool — .gitignore
# ══════════════════════════════════════════════════════════════════════════════

# --- Données (trop volumineuses pour Git) ---
data/raw/
data/interim/
data/processed/
data/external/
*.csv
*.parquet
*.db
*.sqlite

# --- Modèles entraînés ---
models/*.pkl
models/*.pt
models/*.joblib
!models/.gitkeep

# --- Exceptions : artefacts légers du dashboard ---
# Ces CSV de résultats (quelques milliers de lignes) sont nécessaires au
# dashboard Streamlit déployé (Streamlit Cloud clone le repo sans lancer le
# pipeline ML). On les versionne malgré la règle *.csv ci-dessus.
# Générés par `make run-pipeline`, puis à committer pour le déploiement.
!reports/metrics/talent_scores_players.csv
!reports/metrics/clustering_results.csv

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/

# --- Environnement ---
.env
.venv/
venv/
env/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb_checkpoints

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Logs ---
logs/
*.log
